---
import Layout from '../../layouts/Layout.astro';
import { tagUrl, tagThemeSlug, kickerFromArticle, type TagTheme } from '../../lib/tags';
import {
  absoluteMediaUrl,
  absoluteUrl,
  articlePath,
  mergeMarkdownAnchorRelForContent,
  resolveSiteOrigin
} from '../../lib/seo';
import { relatedTopicsForArticle } from '../../lib/taxonomy';
import {
  clipListingExcerpt,
  coverEdgeTintImgAttrs,
  coverImageRequestAttrs,
  getNewsArticleBySlug,
  getRelatedArticles,
  getPrevNextByDate,
  getTaxonomyArticlePool
} from '../../lib/articles-db';
import { sampleCoverEdgeBackdropServer } from '../../lib/cover-edge-color.server';
import { marked } from 'marked';
import sanitizeHtml from 'sanitize-html';

function mergeArticleAnchorRel(attribs: Record<string, string>): Record<string, string> {
  const out = { ...attribs };
  const parts = new Set(
    String(out.rel ?? '')
      .split(/\s+/)
      .map((s) => s.trim())
      .filter(Boolean)
  );
  for (const r of ['nofollow', 'noopener', 'noreferrer']) {
    parts.add(r);
  }
  out.rel = [...parts].join(' ');
  return out;
}

export const prerender = false;

/* Align with home: long SWR on article HTML hid updates to cover_url / cover_type after Telegram edits. */
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=3600'
);

const { slug } = Astro.params;
const article = await getNewsArticleBySlug(slug ?? '');

if (!article) {
  Astro.response.status = 404;
}

const taxonomyPool = await getTaxonomyArticlePool(150);
const relatedArticles = article
  ? await getRelatedArticles(article.slug, article.tags, 6)
  : [];
const nav = article
  ? await getPrevNextByDate(article.created_at, article.slug)
  : { prev: null, next: null };

const exploreTopics = article
  ? relatedTopicsForArticle(article, taxonomyPool, 10)
  : [];

let rawHtml = '';
let htmlContent = '';
let kickerLabel = 'News';
let kickerHref = '/';
let kickerTheme: TagTheme = 'default';
let datePublished = '';
let dateModified: string | null = null;
let description = '';
let canonical = '';
let jsonLdBlocks: object[] = [];

if (article) {
  const contentSiteOrigin = resolveSiteOrigin(Astro.site);
  rawHtml = marked.parse(article.content_md);
  htmlContent = sanitizeHtml(rawHtml, {
    allowedTags: sanitizeHtml.defaults.allowedTags.concat(['img']),
    allowedAttributes: {
      ...sanitizeHtml.defaults.allowedAttributes,
      a: ['href', 'name', 'target', 'rel']
    },
    transformTags: {
      a: (tagName, attribs) => ({
        tagName,
        attribs: mergeMarkdownAnchorRelForContent(attribs, contentSiteOrigin)
      })
    }
  });

  const kicker = kickerFromArticle(article);
  kickerLabel = kicker.label;
  kickerHref = kicker.href;
  kickerTheme = kicker.theme;
  datePublished = new Date(article.created_at).toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
  dateModified = article.updated_at
    ? new Date(article.updated_at).toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      })
    : null;

  const rawMeta =
    article.dek ||
    `${article.content_md.substring(0, 200).replace(/[#*]/g, '').replace(/\s+/g, ' ').trim()}`;
  description = clipListingExcerpt(rawMeta, 158);

  canonical = absoluteUrl(articlePath(article.slug), Astro.site ?? 'https://siliconfeed.online');

  const siteForLd = Astro.site ?? 'https://siliconfeed.online';
  const coverAbsolute = absoluteMediaUrl(article.cover_url, siteForLd);
  const logoAbsolute = absoluteUrl('/logo-512.png', siteForLd);

  const newsLd = {
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: article.title,
    ...(coverAbsolute ? { image: [coverAbsolute] } : {}),
    datePublished: article.created_at,
    dateModified: article.updated_at ?? article.created_at,
    articleSection: kickerLabel,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    author: [
      {
        '@type': 'Organization',
        name: 'SiliconFeed Editorial',
        url: absoluteUrl('/', siteForLd)
      }
    ],
    publisher: {
      '@type': 'Organization',
      name: 'SiliconFeed',
      url: absoluteUrl('/', siteForLd),
      logo: {
        '@type': 'ImageObject',
        url: logoAbsolute,
        width: 512,
        height: 512
      }
    }
  };

  const breadcrumbLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/', siteForLd) },
      {
        '@type': 'ListItem',
        position: 2,
        name: kickerLabel,
        item: absoluteUrl(kickerHref, siteForLd)
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: article.title,
        item: canonical
      }
    ]
  };

  const faqLd =
    article.faq && article.faq.length > 0
      ? {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: article.faq.map((f) => ({
            '@type': 'Question',
            name: f.q,
            acceptedAnswer: {
              '@type': 'Answer',
              text: f.a
            }
          }))
        }
      : null;

  jsonLdBlocks = faqLd ? [newsLd, breadcrumbLd, faqLd] : [newsLd, breadcrumbLd];
}

let companyCoverBackdrop: string | null = null;
if (article?.cover_type === 'company' && article.cover_url) {
  companyCoverBackdrop = await sampleCoverEdgeBackdropServer(article.cover_url);
}

---

{
  article ? (
<Layout
  title={article.title}
  description={description}
  ogImage={article.cover_url}
  ogType="article"
  canonicalUrl={canonical}
  jsonLd={jsonLdBlocks}
>
  <article class="glass article-sheet">
    {
      article.cover_type === 'company' ? (
        <div
          class="cover-edge-frame article-hero-bleed"
          data-cover-edge
          data-cover-edge-done={companyCoverBackdrop ? '1' : undefined}
          style={companyCoverBackdrop ? { backgroundColor: companyCoverBackdrop } : undefined}
        >
          <img
            src={article.cover_url}
            alt={article.title}
            class="cover-edge-frame__img article-hero"
            width="1200"
            height="630"
            loading="eager"
            decoding="async"
            {...coverEdgeTintImgAttrs(article.cover_url, resolveSiteOrigin(Astro.site))}
          />
        </div>
      ) : (
        <div class="article-hero-bleed article-hero-bleed--photo">
          <img
            src={article.cover_url}
            alt={article.title}
            class="article-hero article-hero--cover"
            width="1200"
            height="630"
            loading="eager"
            decoding="async"
            {...coverImageRequestAttrs}
          />
        </div>
      )
    }

    <div class="article-body">
      <a class="article-kicker" href={kickerHref} data-tag-theme={kickerTheme}>
        {kickerLabel}
      </a>

      <h1 class="article-title">{article.title}</h1>

      <div class="article-byline">
        <span>SiliconFeed Editorial</span>
        <span class="article-byline__sep" aria-hidden="true">·</span>
        <time datetime={article.created_at}>{datePublished}</time>
        {
          dateModified && dateModified !== datePublished && (
            <>
              <span class="article-byline__sep" aria-hidden="true">·</span>
              <span>
                updated <time datetime={article.updated_at}>{dateModified}</time>
              </span>
            </>
          )
        }
      </div>

      <div class="article-meta">
        {article.tags.map((tag) => (
          <a href={tagUrl(tag)} class="tag-chip" data-tag-theme={tagThemeSlug(tag)}>
            {tag}
          </a>
        ))}
      </div>

      <p class="article-meta-links">
        Sections and tags — in the Topics menu
        <span class="article-meta-links__sep" aria-hidden="true">·</span>
        <a href="/search">Search the feed</a>
      </p>

      <div class="article-layout">
        <div class="article-main">
          <div class="prose" set:html={htmlContent} />

          <div class="article-signoff">
            <span class="article-signoff__label">Editorial</span>
            SiliconFeed is an automated feed: facts are checked against sources; copy is normalized and lightly edited for
            readers.
          </div>

          <nav class="article-pagination" aria-label="Adjacent stories">
            {
              nav?.prev ? (
                <a href={articlePath(nav.prev.slug)} class="article-pagination__link">
                  <span class="article-pagination__dir">Previous</span>
                  <span class="article-pagination__title">{nav.prev.title}</span>
                </a>
              ) : (
                <div class="article-pagination__spacer" aria-hidden="true" />
              )
            }
            {
              nav?.next ? (
                <a href={articlePath(nav.next.slug)} class="article-pagination__link article-pagination__link--next">
                  <span class="article-pagination__dir">Next</span>
                  <span class="article-pagination__title">{nav.next.title}</span>
                </a>
              ) : (
                <div class="article-pagination__spacer" aria-hidden="true" />
              )
            }
          </nav>
        </div>

        <aside class="aside-stack">
          <div class="aside-panel">
            <h4 class="aside-panel__label">Briefing</h4>
            {(article.entities || []).map((ent) => (
              <div class="entity-block">
                <div class="entity-name">{ent.name}</div>
                <div class="entity-desc">{ent.desc}</div>
              </div>
            ))}
          </div>

          {
            exploreTopics.length > 0 && (
              <div class="aside-panel">
                <h4 class="aside-panel__label">Related topics</h4>
                <ul class="aside-topic-list">
                  {exploreTopics.map((t) => (
                    <li>
                      <a href={t.href} class="aside-topic-list__link">
                        {t.label}
                        <span class="aside-topic-list__kind">{t.kind === 'rubric' ? 'section' : 'tag'}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </aside>
      </div>

      <div class="section-rule">
        {
          article.faq && article.faq.length > 0 && (
            <div style="margin-bottom: 2.5rem;">
              <h3 class="section-title">FAQ</h3>
              <div class="faq-list">
                {article.faq.map((f) => (
                  <details class="faq-item">
                    <summary>{f.q}</summary>
                    <div class="faq-item__body">{f.a}</div>
                  </details>
                ))}
              </div>
            </div>
          )
        }

        <h3 class="section-title">More in the feed</h3>
        <div class="related-grid">
          {relatedArticles.map((rel) => (
            <a href={articlePath(rel.slug)} class="related-card">
              <img src={rel.cover_url} alt={rel.title} loading="lazy" {...coverImageRequestAttrs} />
              <div class="related-card__body">
                <h4 class="related-card__title">{rel.title}</h4>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="article-source">
        <p style="margin: 0 0 0.35rem;">
          Prepared by the editorial stack from public data and external sources.
        </p>
        <a href={article.source_url} target="_blank" rel="nofollow noopener noreferrer">
          Original article
        </a>
      </div>
    </div>
  </article>
</Layout>
  ) : (
<Layout
  title="Page not found"
  description="This story is not in the SiliconFeed archive."
  ogType="website"
  canonicalUrl={absoluteUrl(Astro.url.pathname, Astro.site ?? 'https://siliconfeed.online')}
  noindex={true}
>
  <div class="glass article-sheet" style="padding: 2rem; text-align: center;">
    <h1 class="article-title">404</h1>
    <p>Story not found. Go to the <a href="/">home feed</a>.</p>
  </div>
</Layout>
  )
}

<style>
  .article-main {
    min-width: 0;
  }

  .entity-block + .entity-block {
    margin-top: 0.875rem;
    padding-top: 0.875rem;
    border-top: 1px solid var(--border);
  }

  .article-meta {
    margin-bottom: 0.65rem;
  }

  .article-meta-links {
    margin: 0 0 1.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .article-meta-links a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .article-meta-links a:hover {
    color: var(--accent);
  }

  .article-meta-links__sep {
    margin: 0 0.35rem;
    color: var(--text-faint);
  }

  .aside-topic-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .aside-topic-list li + li {
    margin-top: 0.5rem;
  }

  .aside-topic-list__link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.25rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-main);
    text-decoration: none;
  }

  .aside-topic-list__link:hover {
    color: var(--accent);
  }

  .aside-topic-list__kind {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
</style>
