---
/**
 * /article/[uuid] → 301 to /news/[slug] (demo ids or Supabase UUIDs).
 */
import { getArticleIdSlugMap } from '../../lib/articles-db';
import { articlePath } from '../../lib/seo';

export const prerender = false;

const id = Astro.params.id ?? '';
const map = await getArticleIdSlugMap();
const slug = map.get(id);

if (slug) {
  return Astro.redirect(articlePath(slug), 301);
}

return Astro.redirect('/', 302);
---
