---
/**
 * Старые URL /article/[uuid] → постоянный редирект на /news/[slug].
 * На Vercel дублируется 301 в vercel.json для краевых случаев кэша.
 */
import { getArticleById } from '../../data/news';
import { articlePath } from '../../lib/seo';

export function getStaticPaths() {
  return [
    { params: { id: 'uuid-1' } },
    { params: { id: 'uuid-2' } },
    { params: { id: 'uuid-3' } }
  ];
}

const article = getArticleById(Astro.params.id ?? '');
const target = article ? articlePath(article.slug) : '/';
const canonical = new URL(target, Astro.site ?? 'https://siliconfeed.online').toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <title>Перенаправление…</title>
  </head>
  <body>
    <p><a href={target}>Перейти к материалу</a></p>
  </body>
</html>
