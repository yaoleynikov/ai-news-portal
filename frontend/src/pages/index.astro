---
import Layout from '../layouts/Layout.astro';
import Pagination from '../components/Pagination.astro';
import { tagUrl, tagThemeSlug } from '../lib/tags';
import { absoluteUrl, articlePath, resolveSiteOrigin } from '../lib/seo';
import {
  coverEdgeTintImgAttrs,
  coverImageRequestAttrs,
  getHomeListingPage,
  parseListingPageParam
} from '../lib/articles-db';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=3600'
);

const requestedPage = parseListingPageParam(Astro.url.searchParams.get('page'));
const { featured, river: rest, totalPages, page } = await getHomeListingPage(requestedPage);

function formatListDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

const feedDateLabel = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

const siteOrigin = Astro.site ?? 'https://siliconfeed.online';
const canonicalPath = page > 1 ? `${Astro.url.pathname}?page=${page}` : Astro.url.pathname;
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SiliconFeed',
  url: absoluteUrl('/', siteOrigin),
  description: 'Fresh insights from IT and AI, from SiliconFeed’s automated newsroom.'
};

const articleHref = featured ? articlePath(featured.slug) : '/';

function formatFeaturedStamp(iso: string) {
  return new Date(iso).toLocaleString('en-US', {
    day: 'numeric',
    month: 'short',
    hour: '2-digit',
    minute: '2-digit'
  });
}
---

<Layout
  title="Home"
  description="Fresh insights from IT and AI, from SiliconFeed’s automated newsroom."
  ogType="website"
  canonicalUrl={absoluteUrl(canonicalPath, siteOrigin)}
  jsonLd={websiteLd}
>
  <div class="home-page">
    <h1 class="visually-hidden">SiliconFeed — IT and AI news feed</h1>

    <div class="home-feed-head">
      <p class="home-feed-head__label">In the feed today</p>
      <p class="home-feed-head__date">{feedDateLabel}</p>
    </div>

    {
      featured && (
        <div class="home-featured">
          <div class="home-featured__visual">
            <figure class="home-featured__media">
              {featured.cover_type === 'company' ? (
                <div class="cover-edge-frame cover-edge-frame--featured-inner" data-cover-edge>
                  <img
                    src={featured.cover_url}
                    alt=""
                    class="cover-edge-frame__img home-featured__img"
                    width="1200"
                    height="630"
                    loading="eager"
                    decoding="async"
                    {...coverEdgeTintImgAttrs(featured.cover_url, resolveSiteOrigin(Astro.site))}
                  />
                </div>
              ) : (
                <img
                  src={featured.cover_url}
                  alt=""
                  class="home-featured__img home-featured__img--bleed"
                  width="1200"
                  height="630"
                  loading="eager"
                  decoding="async"
                  {...coverImageRequestAttrs}
                />
              )}
              <a href={articleHref} class="home-featured__media-hit">
                <span class="visually-hidden">{featured.title} — open article</span>
              </a>
              <div class="home-featured__tags-overlay">
                {featured.tags.map((tag) => (
                  <a
                    href={tagUrl(tag)}
                    class="tag-chip tag-chip--hero"
                    data-tag-theme={tagThemeSlug(tag)}
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </figure>
          </div>
          <div class="home-featured__body">
            <p class="home-featured__eyebrow">Lead story</p>
            <h2 class="home-featured__title">
              <a href={articleHref} class="home-featured__title-link">
                {featured.title}
              </a>
            </h2>
            <p class="home-featured__excerpt">{featured.excerpt}</p>
            <div class="home-featured__footer">
              <time class="home-featured__stamp" datetime={featured.created_at}>
                {formatFeaturedStamp(featured.created_at)}
              </time>
              <a href={articleHref} class="home-featured__read">
                Read →
              </a>
            </div>
          </div>
        </div>
      )
    }

    {
      rest.length > 0 && (
        <section class="home-river" aria-labelledby="home-river-heading">
          <h2 id="home-river-heading" class="home-river__heading">
            More
          </h2>
          <ul class="home-river__list">
            {rest.map((article) => (
              <li class="home-river__li">
                <article class="home-river__item">
                  <div class="home-river__text">
                    <h3 class="home-river__title">
                      <a href={articlePath(article.slug)} class="home-river__title-link">
                        {article.title}
                      </a>
                    </h3>
                    <p class="home-river__excerpt">{article.excerpt}</p>
                    <time class="home-river__time" datetime={article.created_at}>
                      {formatListDate(article.created_at)}
                    </time>
                    <div class="home-river__tags">
                      {article.tags.map((tag) => (
                        <a href={tagUrl(tag)} class="tag-chip tag-chip--compact" data-tag-theme={tagThemeSlug(tag)}>
                          {tag}
                        </a>
                      ))}
                    </div>
                  </div>
                  <a
                    href={articlePath(article.slug)}
                    class="home-river__thumb-link"
                    aria-label={`${article.title} — open article`}
                  >
                    <img
                      src={article.cover_url}
                      alt=""
                      class="home-river__thumb"
                      width="140"
                      height="100"
                      loading="lazy"
                      {...coverImageRequestAttrs}
                    />
                  </a>
                </article>
              </li>
            ))}
          </ul>
          <Pagination page={page} totalPages={totalPages} />
        </section>
      )
    }
  </div>
</Layout>
