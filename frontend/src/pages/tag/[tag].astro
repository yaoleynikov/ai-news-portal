---
import Layout from '../../layouts/Layout.astro';
import ListingToolbar from '../../components/ListingToolbar.astro';
import { NAV_TOPICS, articleMatchesTopic, tagUrl, tagThemeSlug } from '../../lib/tags';
import { articlePath } from '../../lib/seo';
import { publicationYears, relatedTopicsForSlug } from '../../lib/taxonomy';
import { getListingArticles } from '../../lib/articles-db';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=120, stale-while-revalidate=3600'
);

function tagLabel(slug: string): string {
  const topic = NAV_TOPICS.find((t) => t.slug === slug);
  if (topic) return topic.label;
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const pool = await getListingArticles(80);
const { tag } = Astro.params;
const label = tag ? tagLabel(tag) : '';

const list = pool.filter((a) => articleMatchesTopic(a.tags, tag ?? ''));
const years = publicationYears(list.length > 0 ? list : pool);
const related = tag ? relatedTopicsForSlug(pool, tag, 14) : [];

function formatListDate(iso: string) {
  return new Date(iso).toLocaleDateString('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---

<Layout
  title={label ? `Метка: ${label}` : 'Метка'}
  description={`Материалы SiliconFeed с меткой «${label}».`}
  ogType="website"
  navArticlePool={pool}
>
  <div class="tag-page">
    <header class="tag-page__head">
      <nav class="tag-page__crumb" aria-label="Навигация">
        <a href="/">Главная</a>
        <span aria-hidden="true">/</span>
        <span class="tag-page__crumb-current">{label}</span>
      </nav>
      <p class="tag-page__kicker">Метка</p>
      <h1 class="tag-page__title">{label}</h1>
      <p class="tag-page__lead">
        Подборка по тегу. Рубрики и все метки — в выпадающем меню <strong>Темы</strong> в шапке; по текстам удобнее{' '}
        <a href="/search">поиск</a>.
      </p>
    </header>

    {
      related.length > 0 && (
        <section class="tag-page__related" aria-labelledby="related-tags-heading">
          <h2 id="related-tags-heading" class="tag-page__related-title">
            Связанные метки
          </h2>
          <p class="tag-page__related-lead">По пересечению с этими материалами — для перелинковки и навигации.</p>
          <ul class="tag-page__related-list">
            {related.map((t) => (
              <li>
                <a href={t.href} class="tag-page__related-link" data-tag-related={t.kind}>
                  <span>{t.label}</span>
                  <span class="tag-page__related-meta">
                    {t.kind === 'rubric' ? 'рубрика' : 'метка'} · {t.count}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      list.length === 0 ? (
        <p class="tag-page__empty">
          Пока нет материалов с этой меткой — откройте меню «Темы» в шапке или <a href="/">главную</a>.
        </p>
      ) : (
        <>
          <ListingToolbar years={years} />
          <ul class="tag-page__list" data-listing-list>
          {list.map((article) => (
            <li
              class="tag-page__li"
              data-listing-item
              data-ts={new Date(article.created_at).getTime()}
              data-year={new Date(article.created_at).getFullYear()}
            >
              <article class="tag-page__card">
                <div class="tag-page__body">
                  <h2 class="tag-page__card-title">
                    <a href={articlePath(article.slug)}>{article.title}</a>
                  </h2>
                  <p class="tag-page__excerpt">{article.excerpt}</p>
                  <time class="tag-page__time" datetime={article.created_at}>
                    {formatListDate(article.created_at)}
                  </time>
                  <div class="tag-page__tags">
                    {article.tags.map((t) => (
                      <a href={tagUrl(t)} class="tag-chip tag-chip--compact" data-tag-theme={tagThemeSlug(t)}>
                        {t}
                      </a>
                    ))}
                  </div>
                </div>
                <a href={articlePath(article.slug)} class="tag-page__thumb-link" aria-label={article.title}>
                  <img src={article.cover_url} alt="" class="tag-page__thumb" width="160" height="100" loading="lazy" />
                </a>
              </article>
            </li>
          ))}
        </ul>
        </>
      )
    }
  </div>
</Layout>
