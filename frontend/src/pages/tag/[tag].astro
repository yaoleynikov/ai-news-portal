---
import Layout from '../../layouts/Layout.astro';
import ListingToolbar from '../../components/ListingToolbar.astro';
import Pagination from '../../components/Pagination.astro';
import type { MockArticle } from '../../data/mock-articles';
import { NAV_TOPICS, articleMatchesTopic, tagUrl, tagThemeSlug } from '../../lib/tags';
import { articlePath } from '../../lib/seo';
import { publicationYears, relatedTopicsForSlug } from '../../lib/taxonomy';
import {
  coverImageRequestAttrs,
  fetchTagPagePayload,
  getListingArticles,
  LISTING_PAGE_SIZE,
  parseListingPageParam,
  TOPIC_LISTING_FETCH_CAP
} from '../../lib/articles-db';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=3600'
);

function tagLabel(slug: string): string {
  const topic = NAV_TOPICS.find((t) => t.slug === slug);
  if (topic) return topic.label;
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const requestedPage = parseListingPageParam(Astro.url.searchParams.get('page'));
const { tag } = Astro.params;
const label = tag ? tagLabel(tag) : '';

let list: MockArticle[] = [];
let page = requestedPage;
let totalPages = 1;
let years: number[] = [];
let related: ReturnType<typeof relatedTopicsForSlug> = [];

if (tag) {
  let rpc = await fetchTagPagePayload(tag, requestedPage);
  if (rpc) {
    totalPages = rpc.total === 0 ? 1 : Math.max(1, Math.ceil(rpc.total / LISTING_PAGE_SIZE));
    page = Math.min(requestedPage, totalPages);
    if (page !== requestedPage) {
      rpc = await fetchTagPagePayload(tag, page);
    }
    if (rpc) {
      list = rpc.list;
      years = rpc.years;
      related = relatedTopicsForSlug(rpc.relatedSources, tag, 14, 'tag');
    }
  } else {
    const pool = await getListingArticles(TOPIC_LISTING_FETCH_CAP);
    const listFull = pool.filter((a) => articleMatchesTopic(a.tags, tag));
    totalPages = listFull.length === 0 ? 1 : Math.max(1, Math.ceil(listFull.length / LISTING_PAGE_SIZE));
    page = Math.min(requestedPage, totalPages);
    const listStart = (page - 1) * LISTING_PAGE_SIZE;
    list = listFull.slice(listStart, listStart + LISTING_PAGE_SIZE);
    years = publicationYears(listFull.length > 0 ? listFull : pool);
    related = relatedTopicsForSlug(pool, tag, 14, 'tag');
  }
}

function formatListDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---

<Layout
  title={label ? `Tag: ${label}` : 'Tag'}
  description={`SiliconFeed stories tagged “${label}”.`}
  ogType="website"
>
  <div class="tag-page">
    <header class="tag-page__head">
      <nav class="tag-page__crumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span class="tag-page__crumb-current">{label}</span>
      </nav>
      <p class="tag-page__kicker">Tag</p>
      <h1 class="tag-page__title">{label}</h1>
      <p class="tag-page__lead">
        Stories with this tag. Sections and all tags live in the <strong>Topics</strong> menu; for full-text use{' '}
        <a href="/search">search</a>.
      </p>
    </header>

    {
      related.length > 0 && (
        <section class="tag-page__related" aria-labelledby="related-tags-heading">
          <h2 id="related-tags-heading" class="tag-page__related-title">
            Related tags
          </h2>
          <p class="tag-page__related-lead">Co-occur with these stories — for navigation and internal links.</p>
          <ul class="tag-page__related-list">
            {related.map((t) => (
              <li>
                <a href={t.href} class="tag-page__related-link" data-tag-related={t.kind}>
                  <span>{t.label}</span>
                  <span class="tag-page__related-meta">
                    {t.kind === 'rubric' ? 'section' : 'tag'} · {t.count}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      list.length === 0 ? (
        <p class="tag-page__empty">
          No stories for this tag yet — open <strong>Topics</strong> in the header or the <a href="/">home feed</a>.
        </p>
      ) : (
        <>
          <ListingToolbar years={years} />
          <ul class="tag-page__list" data-listing-list>
          {list.map((article) => (
            <li
              class="tag-page__li"
              data-listing-item
              data-ts={new Date(article.created_at).getTime()}
              data-year={new Date(article.created_at).getFullYear()}
            >
              <article class="tag-page__card">
                <div class="tag-page__body">
                  <h2 class="tag-page__card-title">
                    <a href={articlePath(article.slug)}>{article.title}</a>
                  </h2>
                  <p class="tag-page__excerpt">{article.excerpt}</p>
                  <time class="tag-page__time" datetime={article.created_at}>
                    {formatListDate(article.created_at)}
                  </time>
                  <div class="tag-page__tags">
                    {article.tags.map((t) => (
                      <a href={tagUrl(t)} class="tag-chip tag-chip--compact" data-tag-theme={tagThemeSlug(t)}>
                        {t}
                      </a>
                    ))}
                  </div>
                </div>
                <a href={articlePath(article.slug)} class="tag-page__thumb-link" aria-label={article.title}>
                  <img
                    src={article.cover_url}
                    alt=""
                    class="tag-page__thumb"
                    width="160"
                    height="100"
                    loading="lazy"
                    {...coverImageRequestAttrs}
                  />
                </a>
              </article>
            </li>
          ))}
        </ul>
          <Pagination page={page} totalPages={totalPages} />
        </>
      )
    }
  </div>
</Layout>
