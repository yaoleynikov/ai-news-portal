---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About"
  description="SiliconFeed — autonomous IT publication: news feed, light analysis, and an editorial pipeline."
  ogType="website"
>
  <article class="glass static-page static-page--boxed">
    <h1 class="static-page__title">About SiliconFeed</h1>
    <p class="static-page__p">
      SiliconFeed is an experimental IT and AI news platform focused on fast delivery, clean layout, and transparent
      sourcing.
    </p>
    <p class="static-page__p">
      Stories are produced by an automated pipeline with editorial guardrails on length and duplicates; primary sources
      are linked from each article.
    </p>
  </article>
</Layout>
