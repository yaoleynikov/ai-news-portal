---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { NAV_TOPICS, rubricUrl } from '../lib/tags';
import { MOCK_ARTICLES } from '../data/mock-articles';
import type { MockArticle } from '../data/mock-articles';
import { buildTopicIndex } from '../lib/taxonomy';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  /** 404 etc. — noindex */
  noindex?: boolean;
  /** Article pool for Themes menu (else static mock). */
  navArticlePool?: MockArticle[];
}

const {
  title,
  description,
  ogImage = '/default-og.webp',
  jsonLd,
  canonicalUrl,
  ogType = 'website',
  noindex = false,
  navArticlePool
} = Astro.props;
const pathname = Astro.url.pathname;
const siteOrigin = Astro.site ?? new URL('https://siliconfeed.online');
const currentCanonical = canonicalUrl || new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteOrigin).toString();

const year = new Date().getFullYear();
const telegramHref = 'https://t.me/siliconfeed';
const mailHref = 'mailto:hello@siliconfeed.online';

const topicIndex = buildTopicIndex(navArticlePool ?? MOCK_ARTICLES);
const themesRubrics = topicIndex.filter((t) => t.kind === 'rubric');
const themesTags = topicIndex.filter((t) => t.kind === 'tag');
const themesNavActive =
  pathname.startsWith('/tag/') || pathname.startsWith('/rubric/');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | SiliconFeed</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentCanonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content={ogType} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    {
      jsonLd &&
        (Array.isArray(jsonLd)
          ? jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)
          : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />)
    }
  </head>
  <body>
    <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-brand">
          <svg class="site-brand__mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path
              class="site-brand__mark-valley"
              d="M3 25.5Q16 22.5 29 25.5"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
            />
            <rect
              class="site-brand__mark-die"
              x="6"
              y="8"
              width="12"
              height="13"
              rx="2.5"
              stroke="currentColor"
              stroke-width="1.75"
            />
            <path
              class="site-brand__mark-stream"
              d="M20 10.5h9M20 14.5h11M20 18.5h8"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
            />
          </svg>
          <span class="site-brand__text">SiliconFeed</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <div class="site-nav__rubrics">
            {
              NAV_TOPICS.map(({ slug, label }) => (
                <a
                  href={rubricUrl(slug)}
                  class:list={[
                    'site-nav__rubric',
                    { 'site-nav__rubric--current': pathname === `/rubric/${slug}` }
                  ]}
                >
                  {label}
                </a>
              ))
            }
          </div>
          <div class="site-nav__extras">
            <div class="site-nav__dropdown">
              <button
                type="button"
                class:list={['site-nav__themes-btn', { 'site-nav__themes-btn--current': themesNavActive }]}
                aria-expanded="false"
                aria-controls="site-themes-panel"
                id="site-themes-btn"
                data-themes-toggle
              >
                Topics
              </button>
              <div
                id="site-themes-panel"
                class="site-nav__themes-panel"
                hidden
                role="region"
                aria-label="Sections and tags"
              >
                <div class="site-nav__themes-panel-inner">
                  <div class="site-nav__themes-col">
                    <p class="site-nav__themes-col-title">Sections</p>
                    <ul class="site-nav__themes-list site-nav__themes-list--rubrics">
                      {
                        themesRubrics.map((t) => (
                          <li>
                            <a href={t.href} class="site-nav__themes-link">
                              <span>{t.label}</span>
                              <span class="site-nav__themes-count">{t.count}</span>
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                  <div class="site-nav__themes-col">
                    <p class="site-nav__themes-col-title">Tags</p>
                    <ul class="site-nav__themes-list">
                      {
                        themesTags.map((t) => (
                          <li>
                            <a href={t.href} class="site-nav__themes-link">
                              <span>{t.label}</span>
                              <span class="site-nav__themes-count">{t.count}</span>
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                </div>
                <div class="site-nav__themes-footer">
                  <a href="/search">Search the feed</a>
                </div>
              </div>
            </div>
            <a
              href="/search"
              class:list={['site-nav__about', { 'site-nav__about--current': pathname === '/search' }]}
            >
              Search
            </a>
            <a href="/about" class:list={['site-nav__about', { 'site-nav__about--current': pathname === '/about' }]}>
              About
            </a>
          </div>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__col">
          <p class="site-footer__heading">Sections</p>
          <ul class="site-footer__list">
            {
              NAV_TOPICS.map(({ slug, label }) => (
                <li>
                  <a href={rubricUrl(slug)}>{label}</a>
                </li>
              ))
            }
            <li>
              <a href="/">Home feed</a>
            </li>
            <li>
              <a href="/search">Search</a>
            </li>
          </ul>
        </div>
        <div class="site-footer__col">
          <p class="site-footer__heading">Publication</p>
          <ul class="site-footer__list">
            <li>
              <a href="/about">About</a>
            </li>
            <li>
              <span class="site-footer__muted">© {year} SiliconFeed</span>
            </li>
          </ul>
        </div>
        <div class="site-footer__col">
          <p class="site-footer__heading">Follow</p>
          <ul class="site-footer__list">
            <li>
              <a href={telegramHref} target="_blank" rel="noopener noreferrer">Telegram</a>
            </li>
            <li>
              <a href="/rss.xml">RSS</a>
            </li>
            <li>
              <a href={mailHref}>Email list</a>
            </li>
          </ul>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        if (window.__siliconfeedThemesNav) return;
        window.__siliconfeedThemesNav = true;

        document.addEventListener('click', (e) => {
          const panel = document.getElementById('site-themes-panel');
          const btn = document.getElementById('site-themes-btn');
          if (!(panel instanceof HTMLElement) || !(btn instanceof HTMLButtonElement)) return;

          if (e.target.closest('#site-themes-panel a')) {
            panel.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
            return;
          }

          if (e.target.closest('[data-themes-toggle]')) {
            e.stopPropagation();
            const open = btn.getAttribute('aria-expanded') === 'true';
            panel.hidden = open;
            btn.setAttribute('aria-expanded', open ? 'false' : 'true');
            return;
          }

          if (btn.getAttribute('aria-expanded') === 'true' && !panel.contains(e.target)) {
            panel.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          const panel = document.getElementById('site-themes-panel');
          const btn = document.getElementById('site-themes-btn');
          if (
            panel instanceof HTMLElement &&
            btn instanceof HTMLButtonElement &&
            btn.getAttribute('aria-expanded') === 'true'
          ) {
            panel.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      })();

      document.addEventListener('astro:page-load', () => {
        const progressBar = document.getElementById('reading-progress');
        if (!progressBar) return;

        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          if (scrollHeight > 0) {
            const progress = (scrollTop / scrollHeight) * 100;
            progressBar.style.width = `${progress}%`;
          } else {
            progressBar.style.width = '0%';
          }
        });
      });
    </script>
  </body>
</html>
