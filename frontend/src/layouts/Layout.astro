---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { NAV_TOPICS, rubricUrl } from '../lib/tags';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  ogImage = '/default-og.webp',
  jsonLd,
  canonicalUrl,
  ogType = 'website'
} = Astro.props;
const pathname = Astro.url.pathname;
const siteOrigin = Astro.site ?? new URL('https://siliconfeed.online');
const currentCanonical = canonicalUrl || new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteOrigin).toString();

const year = new Date().getFullYear();
const telegramHref = 'https://t.me/siliconfeed';
const mailHref = 'mailto:hello@siliconfeed.online';
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | SiliconFeed</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content={ogType} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    {
      jsonLd &&
        (Array.isArray(jsonLd)
          ? jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)
          : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />)
    }
  </head>
  <body>
    <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-brand">
          <svg class="site-brand__mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path
              class="site-brand__mark-valley"
              d="M3 25.5Q16 22.5 29 25.5"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
            />
            <rect
              class="site-brand__mark-die"
              x="6"
              y="8"
              width="12"
              height="13"
              rx="2.5"
              stroke="currentColor"
              stroke-width="1.75"
            />
            <path
              class="site-brand__mark-stream"
              d="M20 10.5h9M20 14.5h11M20 18.5h8"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
            />
          </svg>
          <span class="site-brand__text">SiliconFeed</span>
        </a>
        <nav class="site-nav" aria-label="Основная навигация">
          <div class="site-nav__rubrics">
            {
              NAV_TOPICS.map(({ slug, label }) => (
                <a
                  href={rubricUrl(slug)}
                  class:list={[
                    'site-nav__rubric',
                    { 'site-nav__rubric--current': pathname === `/rubric/${slug}` }
                  ]}
                >
                  {label}
                </a>
              ))
            }
          </div>
          <a href="/about" class:list={['site-nav__about', { 'site-nav__about--current': pathname === '/about' }]}>
            О проекте
          </a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__col">
          <p class="site-footer__heading">Рубрики</p>
          <ul class="site-footer__list">
            {
              NAV_TOPICS.map(({ slug, label }) => (
                <li>
                  <a href={rubricUrl(slug)}>{label}</a>
                </li>
              ))
            }
            <li>
              <a href="/">Главная лента</a>
            </li>
          </ul>
        </div>
        <div class="site-footer__col">
          <p class="site-footer__heading">Издание</p>
          <ul class="site-footer__list">
            <li>
              <a href="/about">О проекте</a>
            </li>
            <li>
              <span class="site-footer__muted">© {year} SiliconFeed</span>
            </li>
          </ul>
        </div>
        <div class="site-footer__col">
          <p class="site-footer__heading">Подписка</p>
          <ul class="site-footer__list">
            <li>
              <a href={telegramHref} target="_blank" rel="noopener noreferrer">Telegram</a>
            </li>
            <li>
              <a href="/rss.xml">RSS</a>
            </li>
            <li>
              <a href={mailHref}>Рассылка (email)</a>
            </li>
          </ul>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const progressBar = document.getElementById('reading-progress');
        if (!progressBar) return;

        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          if (scrollHeight > 0) {
            const progress = (scrollTop / scrollHeight) * 100;
            progressBar.style.width = `${progress}%`;
          } else {
            progressBar.style.width = '0%';
          }
        });
      });
    </script>
  </body>
</html>
