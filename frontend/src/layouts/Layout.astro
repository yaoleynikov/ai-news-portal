---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { NAV_RUBRICS_TOP, NAV_RUBRICS_MORE, NAV_TOPICS, rubricUrl } from '../lib/tags';
import { buildTopicIndex } from '../lib/taxonomy';
import { getTopicIndexPool } from '../lib/articles-db';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  /** 404 etc. — noindex */
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = '/default-og.webp',
  jsonLd,
  canonicalUrl,
  ogType = 'website',
  noindex = false
} = Astro.props;
const pathname = Astro.url.pathname;
const siteOrigin = Astro.site ?? new URL('https://siliconfeed.online');
const currentCanonical = canonicalUrl || new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteOrigin).toString();

const year = new Date().getFullYear();
const telegramHref = 'https://t.me/siliconfeed';
const mailHref = 'mailto:hello@siliconfeed.online';

const topicIndex = buildTopicIndex(await getTopicIndexPool());
const themesRubrics = topicIndex.filter((t) => t.kind === 'rubric');
const themesTags = topicIndex.filter((t) => t.kind === 'tag');
const themesNavActive =
  pathname.startsWith('/tag/') || pathname.startsWith('/rubric/');
const moreRubricSlugs = NAV_RUBRICS_MORE.map((t) => t.slug);
const rubricsMoreNavActive = moreRubricSlugs.some((s) => pathname === `/rubric/${s}`);

/** GA4 web stream; override via PUBLIC_GA_MEASUREMENT_ID on Vercel if needed. */
const gaMeasurementId =
  (import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined)?.trim() || 'G-0456HS5LSV';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | SiliconFeed</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentCanonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content={ogType} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <!-- Google tag (gtag.js) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`} />
    <script
      is:inline
      set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaMeasurementId}');`}
    />

    {
      jsonLd &&
        (Array.isArray(jsonLd)
          ? jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)
          : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />)
    }
  </head>
  <body>
    <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>

    <header class="site-header" id="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-brand">
          <svg class="site-brand__mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path
              class="site-brand__mark-valley"
              d="M3 25.5Q16 22.5 29 25.5"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
            />
            <rect
              class="site-brand__mark-die"
              x="6"
              y="8"
              width="12"
              height="13"
              rx="2.5"
              stroke="currentColor"
              stroke-width="1.75"
            />
            <path
              class="site-brand__mark-stream"
              d="M20 10.5h9M20 14.5h11M20 18.5h8"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
            />
          </svg>
          <span class="site-brand__text">SiliconFeed</span>
        </a>
        <button
          type="button"
          class="site-nav-burger"
          id="site-nav-burger"
          aria-expanded="false"
          aria-controls="site-main-nav"
          aria-label="Open menu"
        >
          <span class="visually-hidden">Menu</span>
          <span class="site-nav-burger__icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
        <div class="site-nav-backdrop" id="site-nav-backdrop" hidden aria-hidden="true"></div>
        <nav class="site-nav" id="site-main-nav" aria-label="Main navigation">
          <div class="site-nav__rubrics">
            {
              NAV_RUBRICS_TOP.map(({ slug, label }) => (
                <a
                  href={rubricUrl(slug)}
                  class:list={[
                    'site-nav__rubric',
                    { 'site-nav__rubric--current': pathname === `/rubric/${slug}` }
                  ]}
                >
                  {label}
                </a>
              ))
            }
            <div class="site-nav__rubrics-more">
              <button
                type="button"
                class:list={[
                  'site-nav__rubrics-more-btn',
                  { 'site-nav__rubrics-more-btn--current': rubricsMoreNavActive }
                ]}
                id="site-rubrics-more-btn"
                aria-expanded="false"
                aria-controls="site-rubrics-more-panel"
                aria-haspopup="true"
                data-rubrics-more-toggle
              >
                More<span class="site-nav__rubrics-more-chevron" aria-hidden="true">▾</span>
              </button>
              <div
                id="site-rubrics-more-panel"
                class="site-nav__rubrics-more-panel"
                hidden
                role="region"
                aria-label="More sections"
              >
                <ul class="site-nav__rubrics-more-list">
                  {
                    NAV_RUBRICS_MORE.map(({ slug, label }) => (
                      <li>
                        <a
                          href={rubricUrl(slug)}
                          class:list={[
                            'site-nav__rubrics-more-link',
                            { 'site-nav__rubrics-more-link--current': pathname === `/rubric/${slug}` }
                          ]}
                        >
                          {label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </div>
          <div class="site-nav__extras">
            <div class="site-nav__dropdown">
              <button
                type="button"
                class:list={['site-nav__themes-btn', { 'site-nav__themes-btn--current': themesNavActive }]}
                aria-expanded="false"
                aria-controls="site-themes-panel"
                id="site-themes-btn"
                data-themes-toggle
              >
                Topics
              </button>
              <div
                id="site-themes-panel"
                class="site-nav__themes-panel"
                hidden
                role="region"
                aria-label="Sections and tags"
              >
                <div class="site-nav__themes-panel-inner">
                  <div class="site-nav__themes-col">
                    <p class="site-nav__themes-col-title">Sections</p>
                    <ul class="site-nav__themes-list site-nav__themes-list--rubrics">
                      {
                        themesRubrics.map((t) => (
                          <li>
                            <a href={t.href} class="site-nav__themes-link">
                              <span>{t.label}</span>
                              <span class="site-nav__themes-count">{t.count}</span>
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                  <div class="site-nav__themes-col">
                    <p class="site-nav__themes-col-title">Tags</p>
                    <ul class="site-nav__themes-list">
                      {
                        themesTags.map((t) => (
                          <li>
                            <a href={t.href} class="site-nav__themes-link">
                              <span>{t.label}</span>
                              <span class="site-nav__themes-count">{t.count}</span>
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                </div>
                <div class="site-nav__themes-footer">
                  <a href="/search">Search the feed</a>
                </div>
              </div>
            </div>
            <a
              href="/search"
              class:list={['site-nav__about', { 'site-nav__about--current': pathname === '/search' }]}
            >
              Search
            </a>
            <a href="/about" class:list={['site-nav__about', { 'site-nav__about--current': pathname === '/about' }]}>
              About
            </a>
          </div>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__col">
          <p class="site-footer__heading">Sections</p>
          <ul class="site-footer__list">
            {
              NAV_TOPICS.map(({ slug, label }) => (
                <li>
                  <a href={rubricUrl(slug)}>{label}</a>
                </li>
              ))
            }
            <li>
              <a href="/">Home feed</a>
            </li>
            <li>
              <a href="/search">Search</a>
            </li>
          </ul>
        </div>
        <div class="site-footer__col">
          <p class="site-footer__heading">Publication</p>
          <ul class="site-footer__list">
            <li>
              <a href="/about">About</a>
            </li>
            <li>
              <a href="/privacy">Privacy Policy</a>
            </li>
            <li>
              <a href="/terms">Terms of Use</a>
            </li>
            <li>
              <span class="site-footer__muted">© {year} SiliconFeed</span>
            </li>
          </ul>
        </div>
        <div class="site-footer__col">
          <p class="site-footer__heading">Follow</p>
          <ul class="site-footer__list">
            <li>
              <a href={telegramHref} target="_blank" rel="noopener noreferrer">Telegram</a>
            </li>
            <li>
              <a href="/rss.xml">RSS</a>
            </li>
            <li>
              <a href={mailHref}>Email list</a>
            </li>
          </ul>
        </div>
      </div>
    </footer>

    <script>
      import { initCoverEdgeFrames } from '../scripts/cover-edge-frame';
      const runCoverEdgeFrames = () => initCoverEdgeFrames();
      runCoverEdgeFrames();
      document.addEventListener('astro:page-load', runCoverEdgeFrames);
    </script>

    <script is:inline>
      (function () {
        if (window.__siliconfeedThemesNav) return;
        window.__siliconfeedThemesNav = true;

        function closeThemesDropdown() {
          const panel = document.getElementById('site-themes-panel');
          const btn = document.getElementById('site-themes-btn');
          if (panel instanceof HTMLElement && btn instanceof HTMLButtonElement) {
            panel.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
          }
        }

        function closeRubricsMoreDropdown() {
          const panel = document.getElementById('site-rubrics-more-panel');
          const btn = document.getElementById('site-rubrics-more-btn');
          if (panel instanceof HTMLElement && btn instanceof HTMLButtonElement) {
            panel.hidden = true;
            btn.setAttribute('aria-expanded', 'false');
          }
        }

        document.addEventListener('click', (e) => {
          const themesPanel = document.getElementById('site-themes-panel');
          const themesBtn = document.getElementById('site-themes-btn');
          const morePanel = document.getElementById('site-rubrics-more-panel');
          const moreBtn = document.getElementById('site-rubrics-more-btn');

          if (e.target.closest('#site-themes-panel a')) {
            closeThemesDropdown();
            return;
          }

          if (e.target.closest('#site-rubrics-more-panel a')) {
            closeRubricsMoreDropdown();
            return;
          }

          if (e.target.closest('[data-themes-toggle]')) {
            e.stopPropagation();
            if (!(themesPanel instanceof HTMLElement) || !(themesBtn instanceof HTMLButtonElement)) return;
            const open = themesBtn.getAttribute('aria-expanded') === 'true';
            if (open) {
              themesPanel.hidden = true;
              themesBtn.setAttribute('aria-expanded', 'false');
            } else {
              closeRubricsMoreDropdown();
              themesPanel.hidden = false;
              themesBtn.setAttribute('aria-expanded', 'true');
            }
            return;
          }

          if (e.target.closest('[data-rubrics-more-toggle]')) {
            e.stopPropagation();
            if (!(morePanel instanceof HTMLElement) || !(moreBtn instanceof HTMLButtonElement)) return;
            const open = moreBtn.getAttribute('aria-expanded') === 'true';
            if (open) {
              morePanel.hidden = true;
              moreBtn.setAttribute('aria-expanded', 'false');
            } else {
              closeThemesDropdown();
              morePanel.hidden = false;
              moreBtn.setAttribute('aria-expanded', 'true');
            }
            return;
          }

          if (
            themesPanel instanceof HTMLElement &&
            themesBtn instanceof HTMLButtonElement &&
            themesBtn.getAttribute('aria-expanded') === 'true' &&
            !themesPanel.contains(e.target) &&
            !themesBtn.contains(e.target)
          ) {
            closeThemesDropdown();
          }
          if (
            morePanel instanceof HTMLElement &&
            moreBtn instanceof HTMLButtonElement &&
            moreBtn.getAttribute('aria-expanded') === 'true' &&
            !morePanel.contains(e.target) &&
            !moreBtn.contains(e.target)
          ) {
            closeRubricsMoreDropdown();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          closeThemesDropdown();
          closeRubricsMoreDropdown();
        });
      })();

      (function () {
        if (window.__siliconfeedMobileNav) return;
        window.__siliconfeedMobileNav = true;

        const mq = window.matchMedia('(max-width: 767px)');

        function els() {
          return {
            header: document.getElementById('site-header'),
            burger: document.getElementById('site-nav-burger'),
            backdrop: document.getElementById('site-nav-backdrop'),
            themesBtn: document.getElementById('site-themes-btn'),
            themesPanel: document.getElementById('site-themes-panel'),
          };
        }

        function closeThemesIfOpen() {
          const { themesBtn, themesPanel } = els();
          if (
            themesBtn instanceof HTMLButtonElement &&
            themesPanel instanceof HTMLElement &&
            themesBtn.getAttribute('aria-expanded') === 'true'
          ) {
            themesPanel.hidden = true;
            themesBtn.setAttribute('aria-expanded', 'false');
          }
          const moreBtn = document.getElementById('site-rubrics-more-btn');
          const morePanel = document.getElementById('site-rubrics-more-panel');
          if (
            moreBtn instanceof HTMLButtonElement &&
            morePanel instanceof HTMLElement &&
            moreBtn.getAttribute('aria-expanded') === 'true'
          ) {
            morePanel.hidden = true;
            moreBtn.setAttribute('aria-expanded', 'false');
          }
        }

        function setMobileNavOpen(open) {
          const { header, burger, backdrop } = els();
          if (!(header instanceof HTMLElement) || !(burger instanceof HTMLButtonElement)) return;
          header.classList.toggle('site-header--nav-open', open);
          burger.setAttribute('aria-expanded', open ? 'true' : 'false');
          burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          if (backdrop instanceof HTMLElement) {
            backdrop.hidden = !open;
            backdrop.setAttribute('aria-hidden', open ? 'false' : 'true');
          }
          document.body.style.overflow = open ? 'hidden' : '';
          if (open) closeThemesIfOpen();
        }

        function toggleMobileNav() {
          const { header } = els();
          if (!(header instanceof HTMLElement)) return;
          setMobileNavOpen(!header.classList.contains('site-header--nav-open'));
        }

        document.addEventListener('click', (e) => {
          if (!mq.matches) return;
          const t = e.target;
          if (!(t instanceof Node)) return;
          if (t.closest && t.closest('#site-nav-burger')) {
            e.preventDefault();
            toggleMobileNav();
            return;
          }
          if (t instanceof Element && t.id === 'site-nav-backdrop') {
            setMobileNavOpen(false);
            return;
          }
          if (t.closest && t.closest('#site-main-nav a[href]')) {
            setMobileNavOpen(false);
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          const { header } = els();
          if (header instanceof HTMLElement && header.classList.contains('site-header--nav-open')) {
            setMobileNavOpen(false);
            e.preventDefault();
          }
        });

        mq.addEventListener('change', () => {
          if (!mq.matches) setMobileNavOpen(false);
        });

        document.addEventListener('astro:page-load', () => {
          setMobileNavOpen(false);
        });
      })();

      document.addEventListener('astro:page-load', () => {
        const progressBar = document.getElementById('reading-progress');
        if (!progressBar) return;

        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          if (scrollHeight > 0) {
            const progress = (scrollTop / scrollHeight) * 100;
            progressBar.style.width = `${progress}%`;
          } else {
            progressBar.style.width = '0%';
          }
        });
      });
    </script>
  </body>
</html>
