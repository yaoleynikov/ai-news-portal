# Copy to .env.local for `astro dev` / set in Vercel → Environment Variables.
# From Supabase: Project Settings → API (URL and anon public key).

PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Vercel (otherwise new /news/[slug] from DB return 404) ---
# 1) Settings → Environment Variables: add BOTH keys above for Production (+ Preview if needed).
# 2) Deploy current frontend from the repo (SSR for /news/*).
# 3) In Supabase apply RLS migration for published read (backend/supabase/migrations/0007_articles_public_read_rls.sql).

# Public R2 bucket URL (same as backend/.env — otherwise covers keep *.r2.cloudflarestorage.com and fail in browser).
# Either name works:
# PUBLIC_R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"
# R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# Google Analytics 4 (gtag on all pages). Measurement ID looks like G-XXXXXXXXXX.
# Admin → Data streams → Web → Measurement ID. Same value as in backend GA4_PROPERTY_ID’s property.
PUBLIC_GA_MEASUREMENT_ID="G-0456HS5LSV"

# After key change: Redeploy on Vercel.
