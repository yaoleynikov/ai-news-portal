# Скопируйте в .env.local для `astro dev` / задайте в Vercel → Environment Variables.
# Берите из Supabase: Project Settings → API (URL и anon public key).

PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Vercel (иначе НОВЫЕ /news/[slug] из БД дадут 404) ---
# 1) Settings → Environment Variables: добавить ОБА ключа выше для Production (+ Preview при необходимости).
# 2) Задеплоить актуальный frontend из репозитория (после перехода на SSR для /news/*).
# 3) В Supabase выполнить миграцию RLS на чтение published (backend/supabase/migrations/0007_articles_public_read_rls.sql).

# Публичный URL бакета R2 (как в backend/.env — иначе обложки останутся с *.r2.cloudflarestorage.com и не откроются в браузере).
# Достаточно одного из двух имён:
# PUBLIC_R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"
# R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# После смены ключа: Redeploy в Vercel.
