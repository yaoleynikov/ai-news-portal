# ==========================================
# SILICONFEED BACKEND ENV
# Copy to .env and fill in. Do not commit .env.
# ==========================================
#
# Worker / Docker не работают без этого файла: ключи не зашиты в образ.
# Минимум для пайплайна статей: SUPABASE_*, OPENROUTER_API_KEY, HF_API_KEY,
# R2_*, LOGODEV (или LOGO_DEV_PUBLISHABLE_KEY) для обложек, PUBLIC_SITE_URL.
#
# Docker — только worker (встроенный RSS ~30 мин):
#   cd backend && cp .env.example .env  → заполнить ключи → docker compose up -d --build

# 1. Supabase (PostgreSQL with pgvector)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Backend worker needs the service_role JWT (Settings -> API). Either name works:
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# SUPABASE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# --- Apply schema (migrations) to cloud project ---
# Option A — SQL Editor: open backend/supabase/APPLY_IN_SQL_EDITOR.sql (entire file),
#   paste into Dashboard → SQL → New query → Run. Do not paste npm commands — not SQL.
#   Or: run `npm run db:print-migrations` and paste only the printed SQL.
# Option B — CLI from backend/:
#   1) Token: https://supabase.com/dashboard/account/tokens  → PowerShell: $env:SUPABASE_ACCESS_TOKEN="sbp_..."
#   2) DB password: Project Settings → Database → Database password
#   3) Project ref — subdomain from SUPABASE_URL (e.g. xxx from https://xxx.supabase.co)
#   npx supabase link --project-ref YOUR_REF -p "YOUR_DB_PASSWORD"
#   npm run db:push
# (config lives in backend/supabase/config.toml after supabase init)

# Canonical origin for links in Telegram / Google Indexing (no trailing slash)
PUBLIC_SITE_URL="https://siliconfeed.online"

# RSS → jobs automation (see src/gatekeeper/feeds.js)
# - Omitted or empty: worker runs embedded gatekeeper every 30 minutes.
# - 0: disable embedded gatekeeper (только если RSS запускаете отдельным процессом вне этого воркера).
# GATEKEEPER_INTERVAL_MS="0"
# Max RSS items scanned per feed per cycle (default 3; cap 50)
# RSS_ITEMS_PER_FEED="3"
# After dedup, only the N freshest items are considered (limits DB + enqueue work; default 36)
# GATEKEEPER_MAX_CANDIDATES="36"

# --- OpenClaw / external cron: RSS digest + Telegram report (see scripts/agent-cycle.mjs) ---
# Worker must run separately to process `jobs`. Cycle only enqueues + summarizes.
# AGENT_CRON_SECRET="generate-a-long-random-string"
# AGENT_HTTP_PORT=8790
# npm run agent:http  then: curl -X POST http://127.0.0.1:8790/api/agent/cycle -H "Authorization: Bearer $AGENT_CRON_SECRET"
# AGENT_STATE_FILE="tmp/last-agent-cycle.json"
# First-run lookback if no state file (minutes)
# AGENT_LOOKBACK_MINUTES=120
# Also post digest to TG_CHANNEL_ID (default: only TG_ADMIN_CHAT_ID)
# AGENT_DIGEST_TO_CHANNEL="0"

# --- Anti-spam: publish & queue caps (worker never exits; it sleeps when capped) ---
# Rolling 60 minutes / UTC calendar day for published articles (status=published).
# Set to 0 to disable that cap. Used only if table worker_publish_limits has no row (see SQL 0008).
# Defaults below ≈ 30/day, 2/hour.
# Rolling 60 minutes: max published articles (default 2/hour)
# PUBLISH_LIMIT_PER_HOUR="2"
# UTC calendar day cap — 0 = disabled (default). Set e.g. 30 to enforce a daily maximum.
# PUBLISH_LIMIT_PER_DAY="0"
# Worker will NOT claim jobs while a cap is exceeded — check startup "Snapshot" in logs.
# How long to sleep when hourly cap is hit (ms)
# PUBLISH_CAP_SLEEP_MS="600000"
# Change caps live (same bot token as notifications): npm run telegram:limits
# Only TG_ADMIN_CHAT_ID is accepted. Optional: TG_LIMITS_POLL_SEC=50
# Max new jobs per gatekeeper RSS cycle (default 6). Use -1 for unlimited (not recommended).
# GATEKEEPER_MAX_ENQUEUE_PER_CYCLE="6"
# If pending jobs >= this, gatekeeper skips enqueue for that cycle (0 = disable backlog guard)
# GATEKEEPER_MAX_PENDING_BACKLOG="35"

# 2. OpenRouter (AI Rewriter)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="openrouter/free"
# Optional — app identification on OpenRouter dashboard
OPENROUTER_HTTP_REFERER="https://siliconfeed.online"
OPENROUTER_APP_TITLE="SiliconFeed"
# Set to 1 only if your model supports OpenAI-style json_object responses (many free models do not).
# OPENROUTER_JSON_OBJECT="1"
# Rewriter response max tokens (JSON with full article); default 10240. Raise if JSON is truncated (e.g. 12288 or 16384).
# REWRITER_MAX_TOKENS="10240"

# 3. Firecrawl (optional; not used by production worker — research scripts only)
FIRECRAWL_API_KEY="fc-your-firecrawl-key"

# 4. Hugging Face (FLUX.1-schnell Image generation)
HF_API_KEY="hf_your_token"
# Optional second account: used if the primary key hits quota / 402 / 429 / 403 etc. (not for 503 cold start).
# HF_API_KEY2="hf_your_second_token"
# Optional override (default uses router.huggingface.co — legacy api-inference returns 410)
# HF_INFERENCE_URL="https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell"

# 5. Logo.dev — img.logo.dev uses the PUBLISHABLE key (pk_...). Secret sk_ keys often get HTTP 401 on image URLs.
# Use one of:
LOGODEV_API_KEY="pk_your_publishable_key"
# LOGO_DEV_PUBLISHABLE_KEY="pk_your_publishable_key"
# LOGO_DEV_TOKEN="pk_your_publishable_key"

# 6. Cloudflare R2 (S3 Compatible)
# Either set full endpoint, or only account id (endpoint is derived automatically):
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="siliconfeed-media"
# Public URL for objects (required for cover images in the browser). Not the same as R2_ENDPOINT:
#   R2 Dashboard → bucket → Public access → URL like https://pub-xxxxxxxx.r2.dev
# Or your custom domain mapped to the bucket.
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# 8. Dev pipeline HTTP server (scripts/dev-pipeline-server.mjs)
# PIPELINE_PORT=8787

# 7. Telegram & Google Indexing API (tell Google “new/updated URL” after each publish)
TG_BOT_TOKEN="123456:ABC..."
TG_ADMIN_CHAT_ID="123456789"
TG_CHANNEL_ID="@yourchannel"
# On worker start: short stats to TG_ADMIN_CHAT_ID (HTML). Set 0 to disable restarts spam.
# TG_WORKER_STARTUP_NOTIFY=0
#
# Telegram admin (удалить / рерайт / обложка + /limits): по умолчанию встроен в `npm run worker` (long poll).
# TG_ADMIN_CHAT_ID = chat.id личного чата с ботом (команда /myid).
# TG_WORKER_TELEGRAM_ADMIN=0 — не запускать встроенный бот в воркере (только sendMessage-уведомления).
# Отдельно без воркера: npm run telegram:admin
# С одним TG_BOT_TOKEN не запускайте одновременно воркер (с ботом) + telegram:limits + telegram:admin — конфликт getUpdates.
# При старте снимается webhook, иначе long poll не получит входящие.
# OPENROUTER_PROMPT_MODEL="openai/gpt-4o-mini"  # опционально: лёгкая модель для сборки промпта обложки из вашей заметки
#
# --- Google Indexing API (required for automatic “please crawl this URL”) ---
# 1) Google Cloud Console → your project → APIs & Services → Enable **Indexing API**.
# 2) IAM → Service Accounts → create account → Keys → Add JSON key; from JSON copy:
#    "client_email" → GOOGLE_SERVICE_ACCOUNT_EMAIL
#    "private_key"   → GOOGLE_PRIVATE_KEY (keep \n as literal backslash-n in .env, or multiline PEM)
# 3) Search Console → property for PUBLIC_SITE_URL host → Settings → Users and permissions →
#    **Add user** → paste the same service account email → role **Owner** (mandatory for Indexing API).
# 4) Test: npm run index:ping -- https://siliconfeed.online/news/your-slug
GOOGLE_SERVICE_ACCOUNT_EMAIL="indexing-bot@PROJECT.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Daily stats → Telegram (21:00 по умолчанию, воркер `npm run worker`) ---
# Включить планировщик в процессе воркера:
STATS_DAILY_REPORT=1
# Часовой пояс для «календарного дня» статей в отчёте и для окна отправки:
STATS_REPORT_TIMEZONE=Europe/Moscow
STATS_REPORT_HOUR=21
STATS_REPORT_MINUTE=0
# Сколько минут подряд допустимо сработать (если воркер проснулся в середине окна):
STATS_FIRE_WINDOW_MIN=3
#
# Search Console: URL ресурса как в GSC (URL-prefix со слэшем или sc-domain:example.com).
# Если пусто — берётся PUBLIC_SITE_URL + /
# GSC_SITE_URL="https://siliconfeed.online/"
#
# GA4 Data API: числовой ID ресурса (Admin → Property settings), НЕ строка G-…
# В GCP включите «Google Analytics Data API». Тот же service account → GA4 Admin →
# Property access management → Add users → Viewer.
# GA4_PROPERTY_ID="123456789"
#
# Опционально: URL Inspection для первых N новых статей дня (квота GSC ~2000/день):
# STATS_URL_INSPECT=1
# STATS_INSPECTION_MAX=5
#
# Ручной запуск отчёта (дата по умолчанию — сегодня в STATS_REPORT_TIMEZONE):
#   npm run stats:report
#   npm run stats:report -- 2026-04-07
#   STATS_REPORT_DATE=2026-04-07 npm run stats:report
