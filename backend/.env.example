# ==========================================
# SILICONFEED BACKEND ENV
# ==========================================

# 1. Supabase (PostgreSQL with pgvector)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key" # For backend worker to bypass RLS

# 2. OpenRouter (AI Rewriter)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="openrouter/free" # OpenRouter auto-load balances the best available free model

# 3. Firecrawl / Trafilatura
FIRECRAWL_API_KEY="fc-1b04a890870a45ddad0156caa5694e57" # Kept for explicit fetching if needed

# 4. Hugging Face (FLUX.1-schnell Image generation)
HF_API_KEY="hf_..."

# 5. Logo.dev
LOGODEV_API_KEY="pk_..."

# 6. Cloudflare R2 (S3 Compatible)
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="siliconfeed-media"

# 7. Telegram & SEO & Social Distribution
TG_BOT_TOKEN="bot_token"
TG_ADMIN_CHAT_ID="admin_id"
TG_CHANNEL_ID="@siliconfeed"
GOOGLE_SERVICE_ACCOUNT_EMAIL="indexing-bot@appspot.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
